---
/**
 * LevelSelector — Pantalla para elegir nivel (1-5).
 */
---

<section class="level-selector hidden" id="level-selector">
  <h1 class="title">Juego Tapete</h1>
  <p class="subtitle">Selecciona un nivel</p>
  <div class="levels">
    {[1, 2, 3, 4, 5].map((n) => (
      <button class="level-btn" data-level={n}>
        Nivel {n}
      </button>
    ))}
  </div>
  <button class="back-btn" id="level-back-btn">← Tipo de juego</button>
</section>

<style>
  .level-selector {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
    background: #0a0a0a;
    color: #fff;
    gap: 2rem;
  }

  .title {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .subtitle {
    font-size: 1.2rem;
    color: #aaa;
  }

  .levels {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .level-btn {
    padding: 1rem 2rem;
    font-size: 1.1rem;
    font-weight: 600;
    background: #1e1e1e;
    color: #fff;
    border: 2px solid #333;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.1s;
  }

  .level-btn:hover {
    background: #2e2e2e;
    border-color: #666;
    transform: translateY(-2px);
  }

  .level-btn:active {
    transform: translateY(0);
  }

  .back-btn {
    background: none;
    border: none;
    color: #888;
    font-size: 0.9rem;
    cursor: pointer;
    margin-top: 1rem;
  }

  .back-btn:hover {
    color: #fff;
  }

  .hidden {
    display: none !important;
  }
</style>
