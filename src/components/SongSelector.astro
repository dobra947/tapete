---
/**
 * SongSelector — Pantalla de selección de canción.
 * Emite "song-selected" con { detail: { song } } al elegir.
 * Las canciones se inyectan vía data-attribute desde index.astro.
 */
---

<section class="song-selector hidden" id="song-selector">
  <h2 class="title">Elige una canción</h2>
  <ul class="song-list" id="song-list"></ul>
  <button class="back-btn" id="song-back-btn">← Volver</button>
</section>

<style>
  .song-selector {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
    background: #0a0a0a;
    color: #fff;
    gap: 2rem;
  }

  .title {
    font-size: 2rem;
    font-weight: 700;
  }

  .song-list {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    width: 100%;
    max-width: 800px;
  }

  :global(.song-item) {
    padding: 2rem;
    width: calc(50% - 0.75rem);
    background: #1e1e1e;
    border: 2px solid #333;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1.6rem;
    text-align: center;
    color: #fff;
    transition: background 0.2s, border-color 0.2s;
  }

  :global(.song-item:hover) {
    background: #2e2e2e;
    border-color: #888;
  }

  .back-btn {
    background: none;
    border: none;
    color: #888;
    font-size: 0.9rem;
    cursor: pointer;
    margin-top: 1rem;
  }

  .back-btn:hover {
    color: #fff;
  }

  .hidden {
    display: none !important;
  }
</style>

